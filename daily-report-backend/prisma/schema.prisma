generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  telegramId   String?   // Removed @unique due to Mongo treating multiple nulls as duplicates
  jiraAccountId String?
  jiraCloudId   String?
  jiraDisplayName String?
  jiraAvatarUrl String?
  jiraConnectedAt DateTime?
  passwordHash String
  name         String
  avatarUrl    String?
  role         String    // "SE", "PM", "Head Delivery", "Sales Engineer", "Head Presales", "Admin"
  team         String    // "Delivery", "Presales", "All"
  status       String    @default("active")  // "active", "suspended", "invited"
  
  // Self-Relation untuk hierarki Atasan-Bawahan
  supervisorId String?   @db.ObjectId
  supervisor   User?     @relation("SupervisorRelation", fields: [supervisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates  User[]    @relation("SupervisorRelation")

  activities   Activity[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Activity {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  actKey         String   // Category/Type of activity
  topic          String?  // Title or topic
  note           String?  // Detailed notes/progress
  dur            Float    // Duration in hours
  date           String   // YYYY-MM-DD
  startTime      String?  // HH:MM
  endTime        String?  // HH:MM
  status         String   @default("completed") // completed, progress
  
  // Jira specific
  source         String   @default("app") // app, jira
  ticketId       String?
  jiraIssueId    String?
  jiraWorklogId  String?
  jiraAuthorAccountId String?
  jiraUpdatedAt  DateTime?
  ticketTitle    String?
  
  // Pre-Sales/PM specific
  customerName   String?
  prName         String?
  nps            Int?
  leadId         String?
  prospectValue  Float?
  
  user           User         @relation(fields: [userId], references: [id])
  attachments    Attachment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Attachment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  activityId String   @db.ObjectId
  filename   String
  path       String
  mimetype   String
  size       Int
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Setting {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MasterActivity {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  actKey      String   @unique // Misal: jira_impl, internal
  label       String   // "Implementation"
  icon        String?  // "🗂"
  color       String?  // "#0D9488"
  colorLo     String?  // "#0D948820"
  team        String   @default("all") // "delivery", "presales", "all"
  source      String   @default("app") // "app", "jira"
  kpiDomain   String?  // "impl", "pm", "enh" dll
  desc        String?  // Penjelasan kecil
  isActive    Boolean  @default(true) // Untuk on/off tanpa menghapus relasi
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
